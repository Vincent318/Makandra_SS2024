@* @author: Vincent Arnold *@
@using Replay.ViewModels.ProcessViewModels
@model ProcessViewModel
@{
    ViewBag.Title = "Prozesse";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background-color: #fff;
            user-select: none;
        }

        .header-container {
            background-color: #fff;
            color: #5a5e63;
            padding: 10px;
            margin-right: 70px;
        }

        .container {
            max-width: 100%;
            margin: 0 auto;
            padding: 0 20px;
        }

        .row {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
        }

        .col {
            flex: 1;
            text-align: left;
            width: 20%;
        }

        .header-title {
            font-weight: bold;
            font-size: 48px;
            margin-right: 30px;
            margin-left: 30px;
            color: #000;
        }

        .dropdown {
            position: relative;
            display: inline-block;
            margin-right: 20px;
        }

        .dropdown button {
            background-color: #ccc;
            color: #000;
            border: none;
            padding: 10px 20px;
            cursor: pointer;
        }

        .dropdown-menu {
            position: absolute;
            background-color: #fff;
            border: 1px solid #ccc;
            min-width: 160px;
            z-index: 1;
            display: none;
        }

        .dropdown-menu a {
            display: block;
            padding: 10px 20px;
            text-decoration: none;
            color: #333;
        }

        .dropdown-menu a:hover {
            background-color: #f0f0f0;
        }

        .dropdown:hover .dropdown-menu {
            display: block;
        }

        .btn {
            color: #000;
            font-weight: bold;
            border: none;
            padding: 10px 20px;
            text-decoration: none;
            cursor: pointer;
            margin-right: 10px;
        }

        .btn:hover {
            background-color: #f0f0f0;
        }

        .search-input {
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 0px;
            font-size: 1em;
            width: 200px;
        }

        .search-bar-container {
            display: inline-block;
            margin-right: 45px;
        }

        .search-icon {
            display: inline-block;
            margin-left: 5px;
            cursor: pointer;
            vertical-align: middle;
            padding: 0;
        }

        .search-icon button {
            background: none;
            border: none;
            padding: 0;
            margin: 0;
            font-size: 1.2em;
            cursor: pointer;
        }

        .table-container {
            background-color: #fff;
            border-left: none;
            border-right: none;
            margin-top: 20px;
        }

        .table-header {
            background: linear-gradient(90deg, #FF0844 0%, #FFB199 100%);
            color: #fff;
            font-weight: bold;
            font-size: 20px;
            display: flex;
            align-items: center;
            padding: 30px;
            padding-left: 10px;
        }

        .table-row {
            display: flex;
            align-items: center;
            padding: 30px;
            border-bottom: 1px solid #ddd;
            cursor: pointer;
        }

        .table-row:last-child {
            border-bottom: none;
        }

        .table-row .col {
            flex: 1;
        }

        .action-icons {
            display: flex;
            align-items: center;
            margin-right: 0px;
        }

        .action-icons form {
            margin-right: 5px; 
        }

        .action-icons button {
            background: none;
            border: none;
            cursor: pointer;
            color: inherit;
        }

        .sub-table {
            display: none;
            background-color: #fff;
            border-top: 1px solid #ddd;
            padding-top: 20px;
        }

        .sub-table-header {
            background: #e0e0e0;
            color: #333;
            font-weight: bold;
            font-size: 16px;
            display: flex;
            align-items: center;
            padding: 15px;
            border-bottom: 1px solid #ddd;
        }

        .sub-table-header .col {
            padding-left: 10px;
        }

        .sub-table-row {
            display: flex;
            align-items: center;
            padding: 30px;
            border-bottom: 1px solid #ddd;
            background-color: #e9ecef;
        }

        .sub-table-row:last-child {
            border-bottom: none;
        }

        .btn-new-task {
            margin-left: 10px;
        }

        .details{
            color: black;
            text-decoration: none;
            margin-left: 70px;
        }

        .details:hover{
            color: blue;
        }

    </style>
</head>
<body>

<div class="header-container">
    <div class="container">
        <div class="row">
            <div class="col">
                <div class="header-title">PROZESSE</div>
            </div>
            
            <div class="col-header">
                <a href="/Processes/CreateProcess" class="btn">+ neuer Prozess</a>
            </div>
        </div>
    </div>
</div>


<div class="container mt-3">
    
    <div class="table-container">
        <div class="table-header" >
            <div class="col">TITEL</div>
            <div class="col">BESCHREIBUNG</div>
            <div class="col">ZUGRIFFSBERECHTIGTE ROLLEN</div>
            <div class="col" style = "text-align: center;">ANZAHL AUFGABEN</div>
            <div class="col" style = "text-align: center;">AKTIONEN</div>
        </div>
        @foreach (var process in Model.Processes)
        {
            <div class="table-row" onclick="toggleSubTable(this)" id="toggle-table">
                
                <div class="col" >@process.Title</div>
                <div class="col">@process.Description</div>
                
                
                <div class="col">
                    <span >
                        @foreach (var role in process.AuthorizedRoles)
                        {   
                            <span class="role-item">@role</span> 
                        }   
                    </span>
                </div>

                <div class = "col"style= "text-align: center;" >
                    <span id="task-count">
                        @process.TaskCount
                    </span>
                </div>

                <div class="col action-icons" >
                    <a onclick="event.stopPropagation();" href="@Url.Action("ActivateProcess", "Processes", new {processId = process.Id})" class="btn"><i class="fas fa-caret-right"></i> Prozess starten</a>
                    <a onclick="event.stopPropagation();" href="@Url.Action("CreateTask", "Processes", new {processId = process.Id})" class="btn btn-new-task" id="add-task-btn">+ Neue Aufgabe</a>
                    <form onclick="event.stopPropagation();" method="post" action="/Processes/DeleteProcess" >
                        <input type="hidden" name="Id" value="@process.Id"/>
                        <button type="submit" class="btn">
                            <img src="~/public/Delete.png" alt="Search Icon" style="width: 28px; height: 28px ; pointer-events: none; vertical-align: middle">
                        </button>
                    </form>
                </div>
            </div>
            <div class="sub-table">
                <div class="sub-table-header">
                    <div class="col">Name</div>
                    <div class="col">Beschreibung</div>
                    <div class="col "></div>
                </div>
                @foreach (var task in process.Tasks)
                {
                    <div class="sub-table-row">
                        <div class="col">
                            <span>@task.Title</span>
                        </div>
                        <div class="col">
                            <span>@Html.Raw(task.Description?.Replace("\n", "<br>"))</span>
                        </div>
                        
                        <div class="col">
                            <a href="@Url.Action("TaskDetails", "Processes", new {taskId = task.Id, processId = task.ProcessId})" class = "details">Details</a>
                        </div>
                        
                    </div>
                     
                } 
                
            </div>
        }
    </div>
</div>

<script>
    function toggleSubTable(element) {
        const subTable = element.nextElementSibling;
        if (subTable.style.display === 'block') {
            subTable.style.display = 'none';
            element.classList.remove('active');
        } else {
            subTable.style.display = 'block';
            element.classList.add('active');
        }
    }

    function selectDropdownItem(item) {
        const dropdownToggle = document.querySelector('.dropdown-toggle');
        dropdownToggle.textContent = item.textContent;
    }

    function deleteProcess(id) {
        if (confirm(`Sind Sie sicher, dass Sie diesen Prozess löschen möchten?`)) {
            fetch('/Processes/DeleteProcess', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify({ id: id })
            })
            .then(response => {
                if (response.ok) {
                    alert(`Prozess wurde erfolgreich gelöscht.`);
                    location.reload();
                } else {
                    throw new Error('Fehler beim Löschen des Prozesses.');
                }
            })
            .catch(error => {
                console.error(error);
                alert('Ein Fehler ist aufgetreten. Bitte versuchen Sie es erneut.');
            });
        }
    }
</script>

</body>
</html>